<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TrituraRoca | Soluciones en Triturados de Roca</title>
    <link rel="stylesheet" href="/Inventario/src/main/resources/static/Styles/Inicio.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Navegación -->
    <nav class="navbar">
        <div class="container nav-container">
            <a href="#" class="logo">
                <i class="fas fa-mountain"></i>
                <span>Tritura<span class="logo-accent">Roca</span></span>
            </a>
            <ul class="nav-menu">
                <li><a href="#inicio">Inicio</a></li>
                <li><a href="#servicios">Servicios</a></li>
                <li><a href="#proyectos">Proyectos</a></li>
                <li><a href="#nosotros">Nosotros</a></li>
                <li><a href="#contacto">Contacto</a></li>
                <li><a href="#" class="btn-login-trigger" id="loginTrigger">Iniciar Sesión</a></li>
            </ul>
            <div class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero" id="inicio">
        <div class="hero-overlay">
            <div class="container">
                <div class="hero-content">
                    <h1 class="hero-title">Trituración de <span class="highlight">Roca</span> de Alta Calidad</h1>
                    <p class="hero-subtitle">Ofrecemos soluciones integrales en trituración de roca para proyectos de construcción, minería e infraestructura</p>
                    <div class="hero-buttons">
                        <a href="#contacto" class="btn-primary">Solicitar Presupuesto</a>
                        <a href="#servicios" class="btn-secondary">Ver Servicios</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="hero-scroll-indicator">
            <i class="fas fa-chevron-down"></i>
        </div>
    </section>

    <!-- Servicios -->
    <section class="services" id="servicios">
        <div class="container">
            <h2 class="section-title">Nuestros <span class="highlight">Servicios</span></h2>
            <p class="section-subtitle">Ofrecemos una amplia gama de servicios en trituración de materiales pétreos</p>
            
            <div class="services-grid">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-hammer"></i>
                    </div>
                    <h3>Trituración Primaria</h3>
                    <p>Reducción inicial de roca de gran tamaño mediante trituradoras de mandíbula y giratorias.</p>
                </div>
                
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-compress-arrows-alt"></i>
                    </div>
                    <h3>Trituración Secundaria</h3>
                    <p>Proceso de reducción adicional para obtener materiales de granulometría específica.</p>
                </div>
                
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-filter"></i>
                    </div>
                    <h3>Clasificación y Cribado</h3>
                    <p>Separación de materiales triturados por tamaño mediante cribas vibratorias.</p>
                </div>
                
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-truck-loading"></i>
                    </div>
                    <h3>Transporte y Logística</h3>
                    <p>Distribución eficiente de materiales triturados a obras y proyectos.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Proyectos Destacados -->
    <section class="projects" id="proyectos">
        <div class="container">
            <h2 class="section-title">Proyectos <span class="highlight">Destacados</span></h2>
            <p class="section-subtitle">Algunos de nuestros trabajos más importantes en los últimos años</p>
            
            <div class="projects-slider">
                <div class="project-card">
                    <div class="project-image">
                        <div class="project-tag">Autopista</div>
                    </div>
                    <div class="project-info">
                        <h3>Autopista Central</h3>
                        <p>Suministro de 50,000 toneladas de base granular para la ampliación de la autopista.</p>
                        <div class="project-stats">
                            <span><i class="fas fa-calendar-alt"></i> 12 meses</span>
                            <span><i class="fas fa-weight-hanging"></i> 50,000 Tn</span>
                        </div>
                    </div>
                </div>
                
                <div class="project-card">
                    <div class="project-image">
                        <div class="project-tag">Minería</div>
                    </div>
                    <div class="project-info">
                        <h3>Minera Cerro Alto</h3>
                        <p>Instalación de planta de trituración móvil para procesamiento de mineral.</p>
                        <div class="project-stats">
                            <span><i class="fas fa-calendar-alt"></i> 8 meses</span>
                            <span><i class="fas fa-weight-hanging"></i> 120,000 Tn</span>
                        </div>
                    </div>
                </div>
                
                <div class="project-card">
                    <div class="project-image">
                        <div class="project-tag">Infraestructura</div>
                    </div>
                    <div class="project-info">
                        <h3>Puerto Industrial</h3>
                        <p>Provisión de materiales pétreos para la construcción del nuevo puerto.</p>
                        <div class="project-stats">
                            <span><i class="fas fa-calendar-alt"></i> 18 meses</span>
                            <span><i class="fas fa-weight-hanging"></i> 85,000 Tn</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div class="cta-content">
                <h2>¿Necesita materiales triturados para su próximo proyecto?</h2>
                <p>Contáctenos para obtener un presupuesto personalizado y asesoría técnica especializada.</p>
                <a href="#contacto" class="btn-primary">Contactar Ahora</a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer" id="contacto">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h3><i class="fas fa-mountain"></i> Tritura<span class="logo-accent">Roca</span></h3>
                    <p>Líderes en soluciones de trituración de roca para la construcción e industria minera.</p>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
                
                <div class="footer-col">
                    <h4>Contacto</h4>
                    <ul class="contact-info">
                        <li><i class="fas fa-map-marker-alt"></i> Av. Industrial 1234, Zona Industrial</li>
                        <li><i class="fas fa-phone"></i> (555) 123-4567</li>
                        <li><i class="fas fa-envelope"></i> info@trituraroca.com</li>
                    </ul>
                </div>
                
                <div class="footer-col">
                    <h4>Enlaces Rápidos</h4>
                    <ul class="footer-links">
                        <li><a href="#inicio">Inicio</a></li>
                        <li><a href="#servicios">Servicios</a></li>
                        <li><a href="#proyectos">Proyectos</a></li>
                        <li><a href="#nosotros">Nosotros</a></li>
                    </ul>
                </div>
                
                <div class="footer-col">
                    <h4>Horario de Atención</h4>
                    <ul class="business-hours">
                        <li>Lunes - Viernes: 7:00 AM - 6:00 PM</li>
                        <li>Sábado: 8:00 AM - 1:00 PM</li>
                        <li>Domingo: Cerrado</li>
                    </ul>
                </div>
            </div>
            
            <div class="footer-bottom">
                <p>&copy; 2023 TrituraRoca. Todos los derechos reservados.</p>
                <p><a href="#" class="btn-login-trigger" id="loginTriggerFooter">Área de Clientes</a></p>
            </div>
        </div>
    </footer>

    <!-- Modal de Login -->
    <div class="modal-overlay" id="loginModal">
        <div class="modal-container">
            <div class="modal-header">
                <h2>Iniciar Sesión</h2>
                <button class="modal-close" id="modalClose">&times;</button>
            </div>
            <div class="modal-body">
                <form id="loginForm">
                    <div class="form-group">
                        <label for="username">Usuario o Email</label>
                        <div class="input-with-icon">
                            <i class="fas fa-user"></i>
                            <input type="text" id="username" placeholder="Ingrese su usuario o email" required>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="password">Contraseña</label>
                        <div class="input-with-icon">
                            <i class="fas fa-lock"></i>
                            <input type="password" id="password" placeholder="Ingrese su contraseña" required>
                            <button type="button" class="toggle-password" id="togglePassword">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="form-options">
                        <label class="checkbox-container">
                            <input type="checkbox" id="rememberMe">
                            <span class="checkmark"></span>
                            Recordarme
                        </label>
                        <a href="#" class="forgot-password">¿Olvidó su contraseña?</a>
                    </div>
                    
                    <button type="submit" class="btn-login">Iniciar Sesión</button>
                    
                    <div class="divider">
                        <span>O continuar con</span>
                    </div>
                    
                    <div class="social-login">
                        <button type="button" class="social-btn google-btn">
                            <i class="fab fa-google"></i> Google
                        </button>
                        <button type="button" class="social-btn microsoft-btn">
                            <i class="fab fa-microsoft"></i> Microsoft
                        </button>
                    </div>
                    
                    <p class="signup-link">¿No tiene una cuenta? <a href="#">Regístrese aquí</a></p>
                </form>
            </div>
        </div>
    </div>

    <script src="/Inventario/src/main/resources/static/Scripts/Inicio.js"></script>
</body>
</html>